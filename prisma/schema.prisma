generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  products    Product[]
  attributes  Attribute[] // رابطه با ویژگی‌های داینامیک
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Attribute {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Brand {
  id          String    @id @default(uuid())
  name        String
  logo        String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  description   String?
  price         Float
  purchasePrice Float?      // قیمت خرید (مخصوص ادمین)
  stock         Int         @default(0) // کل موجودی
  isFeatured    Boolean     @default(false)
  featuredImage String?
  images        String[]    @default([])
  specs         Json?       // ذخیره ویژگی‌ها به صورت JSON
  condition     String?     // فیلد وضعیت محصول
  shippingType  String      @default("PAID") // "FREE" | "PAID"

  variants      ProductVariant[]
  wishlists     Wishlist[]

  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  brandId       String?
  brand         Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String
  colorCode String?
  price     Float?   // قیمت اختصاصی این تنوع (اختیاری)
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model BlogCategory {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
}

model BlogPost {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  featuredImage   String?
  tags            String[]      @default([])
  status          String        @default("draft")
  isFeatured      Boolean       @default(false)
  metaTitle       String?
  metaDescription String?

  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SiteSettings {
  id            String   @id @default("main")
  siteName      String   @default("Aso Shno")
  logo          String?
  contactEmail  String?
  phoneNumber   String?
  footerText    String?
  settings      Json?
  updatedAt     DateTime @updatedAt
}

enum Role {
  ADMIN
  CUSTOMER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ANSWERED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketType {
  CONTACT
  REPAIR
  ORDER_SUPPORT
  TECHNICAL
  OTHER
}

model HomeSlide {
  id          String   @id @default(uuid())
  title       String?
  subtitle    String?
  image       String   // Desktop image
  mobileImage String?  // Mobile image (optional)
  link        String?
  ctaText     String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  textColor   String?
  buttonColor String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority])
  @@index([isActive])
}

model User {
  id            String     @id @default(uuid())
  firstName     String
  lastName      String
  phone         String     @unique
  password      String
  role          Role       @default(CUSTOMER)
  wishlists     Wishlist[]
  tickets       Ticket[]
  messages      Message[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Ticket {
  id            String         @id @default(uuid())
  subject       String
  type          TicketType     @default(CONTACT)
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)

  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages      Message[]

  lastMessageAt DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

model Message {
  id        String   @id @default(uuid())
  content   String   @db.Text
  isAdmin   Boolean  @default(false)
  isRead    Boolean  @default(false)

  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([senderId])
}

model Announcement {
  id           String    @id @default(uuid())
  title        String
  message      String
  type         String    @default("INFO") // INFO, SUCCESS, WARNING, DANGER
  displayMode  String    @default("SMALL") // SMALL (Banner), LARGE (Modal/Card)
  imageUrl     String?
  isActive     Boolean   @default(true)
  startAt      DateTime?
  endAt        DateTime?
  dismissible  Boolean   @default(true)
  priority     Int       @default(0)
  ctaText      String?
  ctaUrl       String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --- Ledger (دفترچه حساب) Models ---

enum LedgerAccountStatus {
  OPEN
  SETTLED
  ARCHIVED
}

enum LedgerTransactionType {
  DEBT_INCREASE       // افزایش بدهی (او به ما)
  DEBT_DECREASE       // کاهش بدهی / طلب ما (ما به او)
  PAYMENT_RECEIVED    // دریافت وجه
  PAYMENT_PAID        // پرداخت وجه
  DISCOUNT            // تخفیف
  ADJUSTMENT_POSITIVE // اصلاح افزایشی
  ADJUSTMENT_NEGATIVE // اصلاح کاهشی
  RETURNED_GOODS      // برگشت کالا
  INITIAL_BALANCE     // مانده اولیه
}

enum LedgerPaymentMethod {
  CASH
  CARD
  TRANSFER
  CHEQUE
  OTHER
}

enum LedgerReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum LedgerReminderRepeat {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model LedgerAccount {
  id            String              @id @default(uuid())
  firstName     String
  lastName      String
  phone         String?
  title         String?             // عنوان یا نام مستعار
  description   String?
  status        LedgerAccountStatus @default(OPEN)
  balance       Decimal             @default(0) // مانده فعلی (مثبت: او بدهکار، منفی: ما بدهکار)

  transactions  LedgerTransaction[]
  reminders     LedgerReminder[]
  auditLogs     LedgerAuditLog[]

  creatorId     String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([phone])
  @@index([lastName, firstName])
  @@index([status])
}

model LedgerTransaction {
  id            String                @id @default(uuid())
  accountId     String
  account       LedgerAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type          LedgerTransactionType
  amount        Decimal               // مبلغ تراکنش (همیشه مثبت در اینجا، جهت توسط نوع تعیین می‌شود)
  balanceBefore Decimal
  balanceAfter  Decimal

  subject       String?               // بابت
  description   String?
  transactionDate DateTime            @default(now()) // تاریخ مالی (انتخابی ادمین)

  paymentMethod LedgerPaymentMethod?
  refNumber     String?               // شماره پیگیری

  items         LedgerTransactionItem[]

  creatorId     String?
  createdAt     DateTime              @default(now()) // تاریخ ثبت واقعی

  @@index([accountId])
  @@index([transactionDate])
  @@index([type])
}

model LedgerTransactionItem {
  id            String            @id @default(uuid())
  transactionId String
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  title         String
  quantity      Decimal           @default(1)
  unitPrice     Decimal
  totalPrice    Decimal

  productId     String?           // ارتباط اختیاری با محصولات سایت
}

model LedgerReminder {
  id            String               @id @default(uuid())
  accountId     String
  account       LedgerAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  title         String?
  dueDate       DateTime
  status        LedgerReminderStatus @default(PENDING)
  repeat        LedgerReminderRepeat @default(NONE)

  lastRemindedAt DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([accountId])
  @@index([dueDate])
  @@index([status])
}

model LedgerAuditLog {
  id            String        @id @default(uuid())
  accountId     String
  account       LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  action        String        // e.g., "CREATE_ACCOUNT", "UPDATE_TRANSACTION"
  details       Json

  adminId       String?
  createdAt     DateTime      @default(now())
}
