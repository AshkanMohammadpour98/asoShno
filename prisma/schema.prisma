generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  products    Product[]
  attributes  Attribute[] // رابطه با ویژگی‌های داینامیک
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Attribute {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Brand {
  id          String    @id @default(uuid())
  name        String
  logo        String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  description   String?
  price         Float
  purchasePrice Float?      // قیمت خرید (مخصوص ادمین)
  stock         Int         @default(0) // کل موجودی
  featuredImage String?
  images        String[]    @default([])
  specs         Json?       // ذخیره ویژگی‌ها به صورت JSON
  condition     String?     // فیلد وضعیت محصول
  shippingType  String      @default("PAID") // "FREE" | "PAID"

  variants      ProductVariant[]

  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  brandId       String?
  brand         Brand?      @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String
  colorCode String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogCategory {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  posts     BlogPost[]
  createdAt DateTime   @default(now())
}

model BlogPost {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  featuredImage   String?
  tags            String[]      @default([])
  status          String        @default("draft")
  isFeatured      Boolean       @default(false)
  metaTitle       String?
  metaDescription String?

  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model SiteSettings {
  id            String   @id @default("main")
  siteName      String   @default("Aso Shno")
  logo          String?
  contactEmail  String?
  phoneNumber   String?
  footerText    String?
  settings      Json?
  updatedAt     DateTime @updatedAt
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  phone         String    @unique
  password      String
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
