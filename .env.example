# -----------------------------------------------------------------------------
# تنظیمات اصلی برنامه (App Configuration)
# -----------------------------------------------------------------------------
# آدرس اصلی سایت. در حالت محلی: http://localhost:3000
# در سرور لیارا: https://asoshno.liara.run
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# تنظیمات دیتابیس (Database Configuration - PostgreSQL)
# -----------------------------------------------------------------------------
# الگو: postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgres://user:password@host:port/dbname"

# -----------------------------------------------------------------------------
# تنظیمات احراز هویت (NextAuth Configuration)
# -----------------------------------------------------------------------------
# همان آدرس NEXT_PUBLIC_APP_URL برای استفاده در بخش بک‌اند
NEXTAUTH_URL=http://localhost:3000
# یک رشته متنی تصادفی و پیچیده برای امنیت توکن‌ها (می‌توانید با دستور `openssl rand -base64 32` بسازید)
NEXTAUTH_SECRET=your_secret_key_here
# برای NextAuth v5 در محیط‌های سرور (مثل لیارا) این مورد ضروری است
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# تنظیمات فضای ابری لیارا (Liara Object Storage / S3)
# -----------------------------------------------------------------------------
LIARA_ENDPOINT=https://storage.iran.liara.space
LIARA_ACCESS_KEY=your_access_key
LIARA_SECRET_KEY=your_secret_key
LIARA_BUCKET_NAME=aso-shno-storage
# آدرس عمومی برای نمایش تصاویر (مثلاً: https://bucket-name.storage.iran.liara.space)
NEXT_PUBLIC_LIARA_URL=https://aso-shno-storage.storage.iran.liara.space
